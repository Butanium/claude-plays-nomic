{
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "mcp__nomic-clerk__*",
      "mcp__nomic-crypto__*"
  ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/debug_log_hook.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/debug_log_hook.py"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/debug_log_hook.py"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/debug_log_hook.py"
          }
        ]
      },
      {
        "matcher": "^(Bash|Write|Edit|AskUserQuestion)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/clerk_tool_restriction.py"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/player_tool_restriction.py"
          }
        ]
      }
    ]
  }
}
